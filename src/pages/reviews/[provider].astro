---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllProviders, getComparisonPairs } from '../../data/providers';
import type { Provider } from '../../data/providers';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const providers = getAllProviders();
  return providers.map(provider => ({
    params: { provider: provider.slug },
    props: { provider },
  }));
};

interface Props {
  provider: Provider;
}

const { provider } = Astro.props;
const p = provider;

const title = `${p.name} Review (2026): Pricing, Features & Pros/Cons`;
const description = `In-depth ${p.name} review covering SMS API pricing, features, compliance, pros and cons, and who it's best for. Updated for 2026.`;

const formatPrice = (price: number | null) => price !== null ? `$${price.toFixed(4)}` : 'N/A';
const formatPriceDollars = (price: number | null) => price !== null ? `$${price.toFixed(2)}` : 'N/A';
const check = (val: boolean) => val ? '\u2705' : '\u274C';

// Find comparison pages that involve this provider
const allProviders = getAllProviders();
const allPairs = getComparisonPairs();
const comparisonLinks = allPairs
  .filter(pair => pair.slugA === p.slug || pair.slugB === p.slug)
  .slice(0, 8)
  .map(pair => {
    const otherSlug = pair.slugA === p.slug ? pair.slugB : pair.slugA;
    const other = allProviders.find(pr => pr.slug === otherSlug)!;
    return { slug: pair.slug, otherName: other.name };
  });

const siteURL = 'https://smsapicompare.com';

const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: `${p.name} SMS API`,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Cloud',
  description: p.tagline,
  offers: p.pricing.sms_outbound_us !== null ? {
    '@type': 'Offer',
    price: p.pricing.sms_outbound_us.toString(),
    priceCurrency: 'USD',
    description: 'Per outbound SMS (US)',
  } : undefined,
  review: {
    '@type': 'Review',
    author: { '@type': 'Organization', name: 'SMS API Compare' },
    reviewBody: `${p.name} is best for ${p.best_for.toLowerCase()}.`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteURL },
    { '@type': 'ListItem', position: 2, name: 'Reviews', item: `${siteURL}/reviews/twilio` },
    { '@type': 'ListItem', position: 3, name: p.name },
  ],
};

const jsonLd = [reviewSchema, breadcrumbSchema];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li class="before:content-['/'] before:mx-2 before:text-gray-300">
          <a href="/" class="hover:text-primary transition-colors">Reviews</a>
        </li>
        <li class="before:content-['/'] before:mx-2 before:text-gray-300">
          <span class="text-gray-900 font-medium">{p.name}</span>
        </li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-16 h-16 rounded-xl bg-primary/10 text-primary font-bold flex items-center justify-center text-2xl">
          {p.name.charAt(0)}
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">{p.name} Review (2026)</h1>
          <p class="text-gray-500 mt-1">{p.tagline}</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-3 text-sm text-gray-500">
        <span>Founded {p.founded}</span>
        <span>&middot;</span>
        <span>{p.hq}</span>
        <span>&middot;</span>
        <a href={p.website} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">{p.website}</a>
      </div>
    </div>

    <!-- Overview -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Overview</h2>
      <p class="text-gray-700 leading-relaxed">
        {p.name} is a cloud communications platform headquartered in {p.hq}, founded in {p.founded}. {p.tagline}. With coverage spanning {p.performance.global_coverage} and an SLA of {p.performance.sla} uptime, {p.name} serves businesses ranging from startups to enterprises.
      </p>
    </section>

    <!-- Pricing -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Pricing</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-xl overflow-hidden">
          <thead>
            <tr class="bg-surface">
              <th class="text-left p-4 font-semibold text-gray-700">Item</th>
              <th class="text-left p-4 font-semibold text-gray-700">Price</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr><td class="p-4 text-gray-600">Outbound SMS (US)</td><td class="p-4 font-mono">{formatPrice(p.pricing.sms_outbound_us)}</td></tr>
            <tr class="bg-surface/50"><td class="p-4 text-gray-600">Inbound SMS (US)</td><td class="p-4 font-mono">{formatPrice(p.pricing.sms_inbound_us)}</td></tr>
            <tr><td class="p-4 text-gray-600">Local Number</td><td class="p-4 font-mono">{formatPriceDollars(p.pricing.phone_number_local)}/mo</td></tr>
            <tr class="bg-surface/50"><td class="p-4 text-gray-600">Toll-Free Number</td><td class="p-4 font-mono">{formatPriceDollars(p.pricing.phone_number_tollfree)}/mo</td></tr>
            <tr><td class="p-4 text-gray-600">Verify / OTP</td><td class="p-4 font-mono">{formatPriceDollars(p.pricing.verify_per_auth)} per auth</td></tr>
            <tr class="bg-surface/50"><td class="p-4 text-gray-600">Volume Discount</td><td class="p-4">{p.pricing.volume_discount}</td></tr>
            <tr><td class="p-4 text-gray-600">Free Trial</td><td class="p-4">{p.pricing.free_trial ? 'Yes' : 'No'}</td></tr>
            <tr class="bg-surface/50"><td class="p-4 text-gray-600">Free Credits</td><td class="p-4 font-mono">{formatPriceDollars(p.pricing.free_credits)}</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Features -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Features</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features.sms)}</span>
          <span class="text-sm text-gray-700">SMS Messaging</span>
        </div>
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features.voice)}</span>
          <span class="text-sm text-gray-700">Voice Calls</span>
        </div>
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features.whatsapp)}</span>
          <span class="text-sm text-gray-700">WhatsApp</span>
        </div>
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features.email)}</span>
          <span class="text-sm text-gray-700">Email</span>
        </div>
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features.verify_otp)}</span>
          <span class="text-sm text-gray-700">Verify / OTP</span>
        </div>
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features.number_lookup)}</span>
          <span class="text-sm text-gray-700">Number Lookup</span>
        </div>
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features.short_code)}</span>
          <span class="text-sm text-gray-700">Short Code</span>
        </div>
        <div class="flex items-center gap-3 bg-white rounded-lg border border-border p-3">
          <span>{check(p.features['10dlc'])}</span>
          <span class="text-sm text-gray-700">10DLC</span>
        </div>
      </div>
      <div class="mt-4 space-y-3">
        <div class="bg-white rounded-lg border border-border p-3">
          <span class="text-sm text-gray-500">Flow Builder:</span>
          <span class="text-sm font-medium text-gray-900 ml-2">{p.features.flow_builder ?? 'None'}</span>
        </div>
        <div class="bg-white rounded-lg border border-border p-3">
          <span class="text-sm text-gray-500">SDK Languages:</span>
          <span class="text-sm font-medium text-gray-900 ml-2">{p.features.sdk_languages.join(', ')}</span>
        </div>
      </div>
    </section>

    <!-- Compliance -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Compliance</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-white rounded-lg border border-border p-4 text-center">
          <div class="text-lg mb-1">{check(p.compliance.hipaa)}</div>
          <div class="text-sm font-medium text-gray-700">HIPAA</div>
        </div>
        <div class="bg-white rounded-lg border border-border p-4 text-center">
          <div class="text-lg mb-1">{check(p.compliance.soc2)}</div>
          <div class="text-sm font-medium text-gray-700">SOC 2</div>
        </div>
        <div class="bg-white rounded-lg border border-border p-4 text-center">
          <div class="text-lg mb-1">{p.compliance.pci_dss ? '\u2705' : '\u274C'}</div>
          <div class="text-sm font-medium text-gray-700">PCI DSS {p.compliance.pci_dss ? `(${p.compliance.pci_dss})` : ''}</div>
        </div>
        <div class="bg-white rounded-lg border border-border p-4 text-center">
          <div class="text-lg mb-1">{check(p.compliance.gdpr)}</div>
          <div class="text-sm font-medium text-gray-700">GDPR</div>
        </div>
      </div>
    </section>

    <!-- Pros & Cons -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Pros & Cons</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-accent/5 border border-accent/20 rounded-xl p-6">
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Pros</h3>
          <ul class="space-y-2">
            {p.pros.map(pro => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-accent mt-0.5 flex-shrink-0">+</span>
                {pro}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-50 border border-red-200 rounded-xl p-6">
          <h3 class="text-sm font-semibold text-red-500 uppercase tracking-wider mb-3">Cons</h3>
          <ul class="space-y-2">
            {p.cons.map(con => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-red-500 mt-0.5 flex-shrink-0">-</span>
                {con}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Best For -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Best For</h2>
      <div class="bg-primary/5 border border-primary/20 rounded-xl p-6">
        <p class="text-gray-700">{p.best_for}</p>
      </div>
    </section>

    <!-- Compare Links -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Compare {p.name}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {comparisonLinks.map(link => (
          <a
            href={`/compare/${link.slug}`}
            class="group flex items-center gap-3 bg-white rounded-xl border border-border p-4 hover:shadow-md hover:border-primary/30 transition-all"
          >
            <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            <span class="text-sm font-medium text-gray-700 group-hover:text-primary transition-colors">
              {p.name} vs {link.otherName}
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section>
      <div class="bg-gradient-to-r from-primary to-secondary rounded-2xl p-8 text-center text-white">
        <h2 class="text-2xl font-bold mb-3">Ready to try {p.name}?</h2>
        <p class="text-white/80 mb-6 max-w-xl mx-auto">
          Visit {p.name}'s website to sign up, or use our pricing calculator to estimate costs.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={p.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white text-primary font-semibold hover:bg-gray-100 transition-colors">
            Visit {p.name}
          </a>
          <a href="/tools/pricing-calculator" class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-white/30 text-white font-semibold hover:bg-white/10 transition-colors">
            Pricing Calculator
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
