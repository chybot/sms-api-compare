---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllProviders, slugPriority } from '../data/providers';
import type { Provider } from '../data/providers';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const providers = getAllProviders();
  const targetSlugs = ['twilio', 'plivo', 'vonage', 'telnyx', 'bandwidth', 'sinch'];
  return targetSlugs.map(slug => {
    const provider = providers.find(p => p.slug === slug)!;
    const alternatives = providers.filter(p => p.slug !== slug);
    return {
      params: { provider: slug },
      props: { provider, alternatives },
    };
  });
};

interface Props {
  provider: Provider;
  alternatives: Provider[];
}

const { provider, alternatives } = Astro.props;

const title = `Top 10 ${provider.name} Alternatives (2026)`;
const description = `Looking for ${provider.name} alternatives? Compare the best SMS API providers as replacements for ${provider.name}, with pricing, features, and pros/cons.`;

// Sort alternatives: those with verdict_vs_twilio first (if provider is twilio), then by price
const sortedAlternatives = [...alternatives].sort((x, y) => {
  const priceA = x.pricing.sms_outbound_us ?? 999;
  const priceB = y.pricing.sms_outbound_us ?? 999;
  return priceA - priceB;
});

const formatPrice = (price: number | null) => price !== null ? `$${price.toFixed(4)}` : 'N/A';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `What are the best alternatives to ${provider.name}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `The top alternatives to ${provider.name} include ${sortedAlternatives.slice(0, 5).map(a => a.name).join(', ')}. Each offers different strengths in pricing, features, and compliance.`,
      },
    },
    {
      '@type': 'Question',
      name: `Is there a cheaper alternative to ${provider.name}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Yes, several providers offer lower per-message pricing than ${provider.name}. ${sortedAlternatives[0]?.name} starts at ${formatPrice(sortedAlternatives[0]?.pricing.sms_outbound_us)} per outbound SMS in the US.`,
      },
    },
    {
      '@type': 'Question',
      name: `Can I switch from ${provider.name} to another provider?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Yes, most SMS API providers support number porting and offer REST APIs that are straightforward to migrate to. The migration typically involves updating your API calls, porting phone numbers, and reconfiguring webhooks.`,
      },
    },
  ],
};

const siteURL = 'https://smsapicompare.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteURL },
    { '@type': 'ListItem', position: 2, name: `${provider.name} Alternatives` },
  ],
};

const jsonLd = [faqSchema, breadcrumbSchema];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li class="before:content-['/'] before:mx-2 before:text-gray-300">
          <span class="text-gray-900 font-medium">{provider.name} Alternatives</span>
        </li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">
        Top 10 {provider.name} Alternatives (2026)
      </h1>
      <p class="mt-4 text-lg text-gray-600 max-w-3xl">
        {provider.name} is a leading SMS API provider, but it may not be the best fit for every team. Here are the top alternatives, ranked by value and relevance.
      </p>
      <div class="mt-4 bg-surface rounded-xl border border-border p-4 inline-block">
        <p class="text-sm text-gray-600">
          <strong>{provider.name} baseline:</strong> Outbound SMS at {formatPrice(provider.pricing.sms_outbound_us)} / msg &middot; {provider.performance.global_coverage} &middot; SLA {provider.performance.sla}
        </p>
      </div>
    </div>

    <!-- Alternatives List -->
    <div class="space-y-6">
      {sortedAlternatives.map((alt, index) => (
        <div class="bg-white rounded-xl border border-border p-6 hover:shadow-md transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-start gap-4">
            <div class="flex-shrink-0">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary font-bold text-sm">
                #{index + 1}
              </span>
            </div>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 mb-2">
                <h2 class="text-xl font-bold text-gray-900">{alt.name}</h2>
                <span class="text-sm text-gray-500">Founded {alt.founded} &middot; {alt.hq}</span>
              </div>
              <p class="text-gray-600 mb-4">{alt.tagline}</p>

              <!-- Key stats -->
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
                <div class="bg-surface rounded-lg p-3 text-center">
                  <div class="text-xs text-gray-500">Outbound SMS</div>
                  <div class="font-semibold text-gray-900 font-mono text-sm">{formatPrice(alt.pricing.sms_outbound_us)}</div>
                </div>
                <div class="bg-surface rounded-lg p-3 text-center">
                  <div class="text-xs text-gray-500">Inbound SMS</div>
                  <div class="font-semibold text-gray-900 font-mono text-sm">{formatPrice(alt.pricing.sms_inbound_us)}</div>
                </div>
                <div class="bg-surface rounded-lg p-3 text-center">
                  <div class="text-xs text-gray-500">SLA</div>
                  <div class="font-semibold text-gray-900 text-sm">{alt.performance.sla}</div>
                </div>
                <div class="bg-surface rounded-lg p-3 text-center">
                  <div class="text-xs text-gray-500">Coverage</div>
                  <div class="font-semibold text-gray-900 text-sm">{alt.performance.global_coverage}</div>
                </div>
              </div>

              <!-- Key differentiator -->
              <p class="text-sm text-gray-600 mb-4">
                <strong>Best for:</strong> {alt.best_for}
              </p>

              <!-- Pros summary -->
              <div class="flex flex-wrap gap-2 mb-4">
                {alt.pros.slice(0, 2).map(pro => (
                  <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium bg-accent/10 text-accent">
                    + {pro}
                  </span>
                ))}
              </div>

              <a
                href={`/compare/${slugPriority(provider.slug) <= slugPriority(alt.slug) ? `${provider.slug}-vs-${alt.slug}` : `${alt.slug}-vs-${provider.slug}`}`}
                class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-dark transition-colors"
              >
                Compare {provider.name} vs {alt.name}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- FAQ -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="group bg-white border border-border rounded-xl">
          <summary class="cursor-pointer p-5 font-semibold text-gray-900 flex items-center justify-between">
            What are the best alternatives to {provider.name}?
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed">
            The top alternatives include {sortedAlternatives.slice(0, 5).map(a => a.name).join(', ')}. Each offers different strengths in pricing, features, and compliance.
          </div>
        </details>
        <details class="group bg-white border border-border rounded-xl">
          <summary class="cursor-pointer p-5 font-semibold text-gray-900 flex items-center justify-between">
            Is there a cheaper alternative to {provider.name}?
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed">
            Yes, several providers offer lower per-message pricing. {sortedAlternatives[0]?.name} starts at {formatPrice(sortedAlternatives[0]?.pricing.sms_outbound_us)} per outbound SMS.
          </div>
        </details>
        <details class="group bg-white border border-border rounded-xl">
          <summary class="cursor-pointer p-5 font-semibold text-gray-900 flex items-center justify-between">
            Can I switch from {provider.name} to another provider?
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed">
            Yes, most SMS API providers support number porting and offer REST APIs that are straightforward to migrate to. The migration typically involves updating your API calls, porting phone numbers, and reconfiguring webhooks.
          </div>
        </details>
      </div>
    </section>

    <!-- CTA -->
    <section class="mt-12">
      <div class="bg-gradient-to-r from-primary to-secondary rounded-2xl p-8 text-center text-white">
        <h2 class="text-2xl font-bold mb-3">Not sure which alternative is right?</h2>
        <p class="text-white/80 mb-6 max-w-xl mx-auto">
          Use our pricing calculator to estimate your monthly costs and find the most affordable provider for your volume.
        </p>
        <a href="/tools/pricing-calculator" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white text-primary font-semibold hover:bg-gray-100 transition-colors">
          Try the Pricing Calculator
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
